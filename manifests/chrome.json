{
  "manifest_version": 3,
  "name": "Surligneur",
  "version": "1.2.0",
  "description": "Surligneur enables to simply highlight text in a web page and to restore it later.",
  "homepage_url": "https://github.com/sarigue/surligneur",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": "icons/icon-32.png",
    "default_title": "Surligneur",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "windows"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_scripts/TextHighlighter-modif.js",
        "content_scripts/surligne.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}