{
  "manifest_version": 2,
  "name": "Surligneur",
  "version": "1.2.0",
  "description": "Surligneur enables to simply highlight text in a web page and to restore it later.",
  "homepage_url": "https://addons.mozilla.org/firefox/addon/surligneur/",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_action": {
    "default_icon": "icons/icon-32.png",
    "default_title": "Surligneur",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_scripts/TextHighlighter-modif.js",
        "content_scripts/surligne.js"
      ]
    }
  ],
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{0d43dcc0-24c1-40c1-8cd0-b92e0c9ec865}"
    }
  }
}